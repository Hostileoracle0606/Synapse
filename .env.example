# Required for live discovery, summarization, embeddings, and chat
GEMINI_API_KEY=

# Optional: improves crawling quality for tough pages and PDFs
FIRECRAWL_API_KEY=

# Optional: leave blank to use the in-memory repository for local hacking
SUPABASE_URL=
SUPABASE_KEY=

# Local worker defaults
REDIS_URL=redis://localhost:6379/0

# Set to true for a quick single-process local setup without a separate Celery worker
CELERY_TASK_ALWAYS_EAGER=true

# Frontend dev server origins allowed by FastAPI
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
